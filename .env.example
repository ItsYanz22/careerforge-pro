# ─────────────────────────────────────────────
# CareerForge Pro — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────
# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/careerforge-pro?retryWrites=true&w=majority

# ── Authentication ────────────────────────────
# Long random string — use: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# ── AI Provider Configuration ──────────────────
# Choose primary AI provider: 'groq' (recommended) or 'gemini'
AI_PROVIDER=groq

# Groq AI (Primary Recommended)
# Get API key from: https://console.groq.com/keys
# Models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=30000

# Gemini AI (Optional Fallback)
# Get API key from: https://makersuite.google.com/app/apikey
# Models: gemini-3.5-flash, gemini-pro
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT=30000

# Fallback Configuration
AI_FALLBACK_ENABLED=true
AI_FALLBACK_PROVIDER=gemini
AI_MAX_RETRIES=2
AI_RETRY_DELAY=1000

# ── Stripe ────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Price ID for the Pro monthly plan (create in Stripe Dashboard → Products)
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_price_id
# Used for Stripe redirect URLs — no trailing slash
FRONTEND_URL=http://localhost:5173

# Vite client-side env vars (must be prefixed with VITE_)
VITE_API_BASE_URL=http://localhost:3000/api
VITE_APP_NAME=CareerForge Pro
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── Puppeteer / PDF Generation ────────────────
# Optional: path to system Chromium binary
# Leave unset to use Puppeteer's bundled Chromium (recommended for local dev)
# Required on Railway/Render/VPS where bundled Chromium may not work:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ── Email (Optional) ──────────────────────────
# SENDGRID_API_KEY=your_sendgrid_api_key
# SENDER_EMAIL=noreply@careerforgepro.com

# ── AWS S3 (Optional — for resume file storage) ──
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=careerforge-pro-resumes
# AWS_REGION=us-east-1
